# Copy to .env.prod on the VM:  cp env.prod.example .env.prod && chmod 600 .env.prod
# Then fill in the values below. Used by: docker compose -f docker-compose.prod.yml --env-file .env.prod

# --- Database ---
POSTGRES_USER=exness_user
# IMPORTANT: use only letters/numbers/dash/underscore. NO '@' ':' '/' '#' characters
# (the password is embedded in DATABASE_URL and would break the URL).
POSTGRES_PASSWORD=CHANGE_ME_strong_password
POSTGRES_DB=exness_trades

# --- Auth ---
# Generate with:  openssl rand -hex 48
JWT_SECRET=CHANGE_ME_openssl_rand_hex_48
TOKEN_EXPIRY=24h

# --- Public URLs (what users type in the browser) ---
# PHASE 1 (testing via IP, before DNS is ready):
WEB_PORT=8088
WEB_BIND=0.0.0.0
PUBLIC_ORIGIN=http://169.58.4.35:8088
PUBLIC_WS_URL=ws://169.58.4.35:8088/ws
# PHASE 2 (after DNS + host nginx + certbot — see deploy/nginx-exness.sanskarshukla.com.conf):
#   WEB_BIND=127.0.0.1
#   PUBLIC_ORIGIN=https://exness.sanskarshukla.com
#   PUBLIC_WS_URL=wss://exness.sanskarshukla.com/ws
# then rebuild frontend:  docker compose -f docker-compose.prod.yml --env-file .env.prod up -d --build frontend

# --- Kafka (only change if sharing an existing Kafka broker) ---
KAFKA_TOPIC=trades
KAFKA_GROUP_ID=exness_consumer_group

# --- Trading ---
INITIAL_BALANCE_USD=5000

# --- OAuth (optional; leave empty to disable buttons — email/password still works) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
